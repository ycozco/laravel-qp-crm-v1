# Copia preferida:
# cp .env.server-test.example .env.server-test
#
# Este archivo replica la misma base para documentacion.

APP_NAME="QP CRM"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://admincrm1.qpsecure.cloud
APP_KEY=
APP_TIMEZONE=UTC
CRM_ROOT_REDIRECT_URL=https://admincrm1.qpsecure.cloud/crm

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=crm1_mysql
DB_PORT=3306
DB_DATABASE=crm1
DB_USERNAME=crm1
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_DOMAIN=.qpsecure.cloud
SESSION_SECURE_COOKIE=true

REDIS_CLIENT=phpredis
REDIS_HOST=crm1_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

LARAVEL_CRM_OWNER=admincrm1@qpsecure.cloud
LARAVEL_CRM_ROUTE_SUBDOMAIN=admincrm1
LARAVEL_CRM_ROUTE_PREFIX=crm
LARAVEL_CRM_USER_INTERFACE=true
LARAVEL_CRM_ENCRYPT_DB_FIELDS=true

# `crmapi.qpsecure.cloud` comparte backend con `admincrm1` en server-test.
# No incluir `crm1app.qpsecure.cloud` hasta que exista una app separada real.
CORS_ALLOWED_ORIGINS=https://admincrm1.qpsecure.cloud,https://crm1.qpsecure.cloud

CRM_OWNER_NAME=Admin CRM1
CRM_OWNER_EMAIL=admincrm1@qpsecure.cloud
CRM_OWNER_PASSWORD=change-this-password
CRM_SEED_SERVER_TEST_DEMO=true
CRM_DEMO_PASSWORD=Secret123!

META_WHATSAPP_ENABLED=true
META_WHATSAPP_GRAPH_VERSION=v21.0
META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-this-token
META_WHATSAPP_WEBHOOK_PATH=/webhooks/meta/whatsapp
META_WHATSAPP_WEBHOOK_REQUIRE_SIGNATURE=true
META_WHATSAPP_WEBHOOK_ALLOW_FALLBACK_TENANT=false
