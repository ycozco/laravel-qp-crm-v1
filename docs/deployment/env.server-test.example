APP_NAME="Laravel CRM Server Test"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://crm.midominio.com

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel_crm
DB_USERNAME=laravel_crm
DB_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379

LARAVEL_CRM_ROUTE_PREFIX=crm
LARAVEL_CRM_OWNER=admin@crm.midominio.com
LARAVEL_CRM_USER_INTERFACE=true

META_WHATSAPP_ENABLED=true
META_WHATSAPP_GRAPH_VERSION=v21.0
META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me
META_WHATSAPP_WEBHOOK_PATH=/api/webhooks/meta/whatsapp

