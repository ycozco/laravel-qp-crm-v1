APP_NAME="Laravel CRM Local"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8088

DB_CONNECTION=mysql
DB_HOST=laravel_crm_mysql
DB_PORT=3306
DB_DATABASE=laravel_crm
DB_USERNAME=laravel_crm
DB_PASSWORD=laravel_crm

REDIS_HOST=laravel_crm_redis
REDIS_PORT=6379

LARAVEL_CRM_ROUTE_PREFIX=crm
LARAVEL_CRM_OWNER=admin@crm-laravel.local
LARAVEL_CRM_USER_INTERFACE=true

META_WHATSAPP_ENABLED=false
META_WHATSAPP_GRAPH_VERSION=v21.0
META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=local-test-verify-token
META_WHATSAPP_WEBHOOK_PATH=/api/webhooks/meta/whatsapp

